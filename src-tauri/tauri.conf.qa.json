{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Effective Recorder QA",
  "version": "0.1.0",
  "identifier": "com.effective-recorder.qa",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Effective Recorder QA",
        "width": 380,
        "height": 520,
        "minWidth": 340,
        "minHeight": 460,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "macOS": {
      "entitlements": "Entitlements.plist",
      "signingIdentity": null,
      "providerShortName": null
    }
  }
}
